{
  "name": "Login-Logout-auth-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/Login-Logout-auth-app/src",
  "prefix": "app",
  "targets": {
    "build": {
      "executor": "@angular-architects/module-federation:build",
      "options": {
        "outputPath": "dist/Login-Logout-auth-app",
        "index": "apps/Login-Logout-auth-app/src/index.html",
        "main": "apps/Login-Logout-auth-app/src/main.ts",
        "tsConfig": "apps/Login-Logout-auth-app/tsconfig.app.json"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "sourceMap": true,
          "extractLicenses": false,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "development"
    },
    "serve": {
      "executor": "@nx/angular:dev-server",
      "options": {
        "port": 4216
      },
      "configurations": {
        "production": {
          "buildTarget": "Login-Logout-auth-app:build:production"
        },
        "development": {
          "buildTarget": "Login-Logout-auth-app:build:development"
        }
      },
      "defaultConfiguration": "development"
    }
  }
}