{
  "name": "vn-core-ui-components",
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "includedScripts": [],
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/ui-components/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-builders/custom-webpack:browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/ui-components",
        "index": "apps/ui-components/src/index.html",
        "main": "apps/ui-components/src/main.ts",
        "customWebpackConfig": {
          "path": "apps/ui-components/webpack.config.js"
        },
        "tsConfig": "apps/ui-components/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/ui-components/public"
          }
        ],
        "styles": ["apps/ui-components/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular-builders/custom-webpack:dev-server",
      "options": {
        "port": 4214,
        "publicHost": "http://localhost:4214"
      },
      "configurations": {
        "production": {
          "buildTarget": "vn-core-ui-components:build:production"
        },
        "development": {
          "buildTarget": "vn-core-ui-components:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "apps/ui-components/src/**/*.ts",
          "apps/ui-components/src/**/*.html"
        ]
      }
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {}
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "vn-core-ui-components:build",
        "port": 4200,
        "staticFilePath": "dist/vn-core-ui-components/browser",
        "spa": true
      }
    }
  }
}
